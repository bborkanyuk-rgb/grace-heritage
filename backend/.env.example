# Port to run backend server on
PORT=3000

# Your official Monobank Merchant Token from https://fop.monobank.ua/
MONO_TOKEN=your_monobank_merchant_token

# Google Apps Script Web App URL for log entries and status updates
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/.../exec

# Telegram configuration (falls back to built-in tokens if left blank)
TELEGRAM_BOT_TOKEN=8551709614:AAG0cPhDj0MasK0EJjfOc1Vb7NOi_5cVIcc
TELEGRAM_CHAT_ID=-1003941811035

# Redirect URL after successful payment completion on Monobank page
SUCCESS_REDIRECT_URL=https://grace-heritage.shop/index.html?status=success

# Public domain of your backend deployment (needed for webhooks, e.g. https://api.grace-heritage.shop)
# Note: Webhooks won't work locally without an ngrok tunnel
WEBHOOK_URL=https://your-backend-domain.com
